{
  "version": "0.2.0",

  // ============================================================
  // Debug Configurations
  // ============================================================
  "configurations": [
    // ============================================================
    // CLI
    // ============================================================
    {
      "name": "nssmr: Debug CLI (usage)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nssmr",
      "cwd": "${workspaceFolder}",
      "env": {
        "GOCACHE": "${workspaceFolder}/.gocache",
        "GOMODCACHE": "${workspaceFolder}/.gomodcache",
        "CGO_ENABLED": "0"
      }
    },
    {
      "name": "nssmr: Debug CLI (version)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nssmr",
      "cwd": "${workspaceFolder}",
      "args": ["version"],
      "env": {
        "GOCACHE": "${workspaceFolder}/.gocache",
        "GOMODCACHE": "${workspaceFolder}/.gomodcache",
        "CGO_ENABLED": "0"
      }
    },
    {
      "name": "nssmr: Debug CLI (list services)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nssmr",
      "cwd": "${workspaceFolder}",
      "args": ["list"],
      "env": {
        "GOCACHE": "${workspaceFolder}/.gocache",
        "GOMODCACHE": "${workspaceFolder}/.gomodcache",
        "CGO_ENABLED": "0"
      }
    },
    {
      "name": "nssmr: Debug CLI (prompt for args)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/nssmr",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}",
      "env": {
        "GOCACHE": "${workspaceFolder}/.gocache",
        "GOMODCACHE": "${workspaceFolder}/.gomodcache",
        "CGO_ENABLED": "0"
      }
    },

    // ============================================================
    // Tests
    // ============================================================
    {
      "name": "nssmr: Debug Current Package Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
      "env": {
        "GOCACHE": "${workspaceFolder}/.gocache",
        "GOMODCACHE": "${workspaceFolder}/.gomodcache",
        "CGO_ENABLED": "0"
      }
    }
  ]
}
